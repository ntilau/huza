<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Android → Chrome → macOS Notification Center"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="32dp" />

    <TextView
        android:id="@+id/listener_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notification access: CHECKING..."
        android:textSize="16sp"
        android:textStyle="bold" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="8dp" />

    <TextView
        android:id="@+id/config_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ntfy.sh topic: CHECKING..."
        android:textSize="16sp"
        android:textStyle="bold" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="32dp" />

    <Button
        android:id="@+id/btn_notification_access"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Notification Access" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="8dp" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configure ntfy.sh Topic"
        style="@style/Widget.AppCompat.Button.Colored" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="1. Tap &quot;Configure ntfy.sh Topic&quot; to generate a topic\n2. Enable notification access above\n3. On your Mac, open Chrome and go to:\n   https://ntfy.sh/your-topic-name\n4. Allow notifications in Chrome → done!"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp" />

</LinearLayout>
